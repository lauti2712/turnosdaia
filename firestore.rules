rules_version = '2';

// Sin login: cualquiera con la URL puede leer/escribir. Válido para uso
// personal con URL no compartida. Si en algún momento se necesita
// autenticación, agregar Firebase Auth y condicionar acá con request.auth.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
